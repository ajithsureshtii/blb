ARG BASE_IMAGE=blb-seal
FROM ${BASE_IMAGE}

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir \
    torch --index-url https://download.pytorch.org/whl/cpu \
    transformers \
    datasets \
    numpy \
    scipy \
    --break-system-packages

# Copy repo and build SCI with SEAL backend.
# SEAL 4.1.1 is cloned and built automatically by CMake (extern/SEAL submodule).
COPY . /root/blb
WORKDIR /root/blb/SCI

RUN mkdir -p build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=./install \
        -DBUILD_TESTS=ON && \
    cmake --build . --parallel $(nproc) && \
    cmake --install .

WORKDIR /root/blb
EXPOSE 1234
CMD ["bash"]
